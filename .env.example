# =======================================================================
# Choose ONE LLM provider below.
# Keep only one provider block uncommented in .env.
# =======================================================================

## Option 1: Hugging Face Inference API (remote)
LLM_PROVIDER=hf
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=your-huggingface-token


## Option 2: Google Gemini (remote)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=your-gemini-api-key


## Option 3: OpenAI (remote)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-openai-api-key


## Option 4: Ollama (local; API key is ignored but kept for config shape)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# LLM_API_KEY=not-used
# OLLAMA_BASE_URL=http://localhost:11434
## Docker-to-host Ollama URL:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# =======================================================================

## LLM settings (optional)
LLM_MAX_CHUNKS=5
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

## Chunk settings
CHUNK_SIZE=800
CHUNK_OVERLAP=200

## Retrieval settings
TOP_K=5
MIN_RETRIEVAL_SCORE=0.3

## Output settings
STREAM=true
LINE_WIDTH=80

# =======================================================================
# Evaluation
# =======================================================================
# LLM_EVAL_PROVIDER=gemini
# LLM_EVAL_MODEL=gemini-2.0-flash
# LLM_EVAL_API_KEY=your-gemini-api-key
